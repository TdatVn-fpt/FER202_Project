          "id": "C",
          "text": "The examiner's score"
        },
        {
          "id": "D",
          "text": "All unknown words"
        }
      ],
      "correctOptionId": "B",
      "answer": "B",
      "explanation": "Prediction helps listeners focus on expected information.",
