  "questions": [
    {
      "id": "q-001",
      "testId": "test-001",
      "questionText": "What is the main purpose of skimming?",
      "options": [
        {
          "id": "A",
          "text": "To translate every sentence"
        },
        {
          "id": "B",
          "text": "To get the general idea quickly"
        },
        {
          "id": "C",
          "text": "To memorize all vocabulary"
        },
        {
          "id": "D",
          "text": "To answer only grammar questions"
        }
      ],
      "correctOptionId": "B",
      "answer": "B",
      "explanation": "Skimming helps readers understand the general idea before reading details.",
      "order": 1,
      "score": 1
    },
    {
      "id": "q-002",
      "testId": "test-001",
      "questionText": "Which question type often requires careful evidence checking?",
      "options": [
        {
          "id": "A",
          "text": "True False Not Given"
        },
        {
          "id": "B",
          "text": "Cue Card"
        },
        {
          "id": "C",
          "text": "Map Labelling"
        },
        {
          "id": "D",
          "text": "Sentence Stress"
        }
      ],
      "correctOptionId": "A",
      "answer": "A",
      "explanation": "TFNG questions require comparing the statement with evidence in the passage.",
      "order": 2,
      "score": 1
    },
    {
      "id": "q-003",
      "testId": "test-001",
      "questionText": "In Matching Headings, what should students read first?",
      "options": [
        {
          "id": "A",
          "text": "Only examples"
        },
        {
          "id": "B",
          "text": "Topic sentences and paragraph focus"
        },
        {
          "id": "C",
          "text": "The answer key"
        },
        {
          "id": "D",
          "text": "Unrelated footnotes"
        }
      ],
      "correctOptionId": "B",
      "answer": "B",
      "explanation": "Topic sentences and paragraph focus usually reveal the best heading.",
      "order": 3,
      "score": 1
    },
    {
      "id": "q-004",
      "testId": "test-001",
      "questionText": "Scanning is most useful when looking for:",
      "options": [
        {
          "id": "A",
          "text": "Specific names, numbers, or keywords"
        },
        {
          "id": "B",
          "text": "A full essay plan"
        },
        {
          "id": "C",
          "text": "Pronunciation features"
        },
        {
          "id": "D",
          "text": "Speaking fluency"
        }
      ],
      "correctOptionId": "A",
      "answer": "A",
      "explanation": "Scanning means searching quickly for specific information.",
      "order": 4,
      "score": 1
    },
    {
      "id": "q-005",
      "testId": "test-002",
      "questionText": "Before listening, students should predict:",
      "options": [
        {
          "id": "A",
          "text": "The exact transcript"
        },
        {
          "id": "B",
          "text": "The answer type and context"
        },
